#!/bin/bash
# MarketPulse Pre-commit Hook — 민감 정보 유출 방지
# 설치: git config core.hooksPath .githooks

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "🔒 민감 정보 체크..."

ERRORS=0

# 1. 민감 파일이 스테이징에 포함되었는지 확인
SENSITIVE_FILES=(
  ".env"
  "mcp_agent.secrets.yaml"
  "trading/config/kis_devlp.yaml"
  ".kis_token.json"
)

for f in "${SENSITIVE_FILES[@]}"; do
  if git diff --cached --name-only | grep -qx "$f"; then
    echo -e "${RED}❌ 민감 파일 커밋 차단: $f${NC}"
    ERRORS=$((ERRORS + 1))
  fi
done

# 2. 스테이징된 파일 내용에 실제 키/비밀번호 패턴이 있는지 스캔
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py|tsx?|ts|json|yaml|yml|sh|md)$')

if [ -n "$STAGED_FILES" ]; then
  # API 키 패턴
  if echo "$STAGED_FILES" | xargs grep -lnE 'sk-ant-api[0-9a-zA-Z_-]{20,}|sk-proj-[0-9a-zA-Z_-]{20,}' 2>/dev/null; then
    echo -e "${RED}❌ API 키 하드코딩 발견!${NC}"
    ERRORS=$((ERRORS + 1))
  fi

  # 계좌번호 패턴 (8자리-2자리) — example/SETUP 문서 제외
  if echo "$STAGED_FILES" | xargs grep -lnE '"[0-9]{8}-[0-9]{2}"' 2>/dev/null | grep -v example | grep -v SETUP; then
    echo -e "${RED}❌ 계좌번호 패턴 발견!${NC}"
    ERRORS=$((ERRORS + 1))
  fi

  # KIS appkey/appsecret 실제 값 (PSb로 시작하는 32자리 등)
  if echo "$STAGED_FILES" | xargs grep -lnE 'appkey:\s*"?PS[a-zA-Z0-9]{10,}|appsecret:\s*"?[a-zA-Z0-9]{30,}' 2>/dev/null | grep -v example; then
    echo -e "${RED}❌ KIS API 키 발견!${NC}"
    ERRORS=$((ERRORS + 1))
  fi

  # 비밀번호 직접 노출
  if echo "$STAGED_FILES" | xargs grep -lnE 'password\s*[:=]\s*"[^"]{4,}"' 2>/dev/null | grep -v example | grep -v test; then
    echo -e "${RED}❌ 비밀번호 하드코딩 발견!${NC}"
    ERRORS=$((ERRORS + 1))
  fi
fi

# 3. 결과
if [ $ERRORS -gt 0 ]; then
  echo ""
  echo -e "${RED}🚫 커밋 차단: ${ERRORS}개 민감 정보 발견${NC}"
  echo "  해결: 민감 파일을 unstage하거나, 키를 환경변수로 교체하세요."
  echo "  우회: git commit --no-verify (권장하지 않음)"
  exit 1
fi

echo -e "${GREEN}✅ 민감 정보 체크 통과${NC}"
exit 0
